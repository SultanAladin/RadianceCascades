#version 450
// Phase 14b — Radiance Cascade hash relight pass.
// Phase 15e — sparse SDF: the sampler3D bind point is replaced by a sparse-VDB
// pair (BrickIndex SSBO + BrickPool SSBO) plus a SparseParams UBO. The hot
// sphere-trace loop uses the brick-aware ray helper, so cascade rays cross
// empty space in one step instead of grinding voxel-by-voxel.
//
// One workgroup per occupied cell (sourced from CellList[1..count]). Trace
// rays into the SDF, sample direct lighting at the hit (sun · NdotL · SDF
// cone-shadow), or look up the next-cascade SH probe at the miss endpoint
// (radiance-interval extension, Taichi C4-validated). Accumulate into SH-L1
// luma (4 bands × 1 channel = 1 vec4) and write to ProbePayload.
//
// Descriptor sets:
//   set=0 : Sparse SDF
//           binding 0 = SparseIdx  SSBO  (uint BrickIndex[BrickGrid^3])
//           binding 1 = SparsePool SSBO  (uint BrickPool[occupied*bs^3/2])
//           binding 2 = SparseParams UBO (SparseSDFParams)
//   set=1 : RcHash (same 4 bindings as rc_insert)

#extension GL_GOOGLE_include_directive : require

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

#include "include/sdf_sparse.glsl"

layout(std430, set = 0, binding = 0) readonly buffer SparseIdx  { uint Data[]; } uSparseIdx;
layout(std430, set = 0, binding = 1) readonly buffer SparsePool { uint Data[]; } uSparsePool;
layout(std140, set = 0, binding = 2) uniform SparseParamsBuf { SparseSDFParams P; } uSparseP;

SDFSPARSE_DEFINE_HELPER    (uSparseIdx, uSparsePool)
SDFSPARSE_DEFINE_RAY_HELPER(uSparseIdx, uSparsePool)

#include "include/rc_hash.glsl"
#include "include/sdf_trace.glsl"

SDFTRACE_DEFINE_SPARSE_HELPERS()

// ----------------------- set=1: RC hash ---------------------------------------
layout(std430, set = 1, binding = 0) buffer RC_KeyBuf     { uint  gRC_Keys[];     };
layout(std430, set = 1, binding = 1) buffer RC_PayloadBuf { vec4  gRC_Payload[];  };
layout(std140, set = 1, binding = 2) uniform RC_ParamsBuf { RcParams gRC_P; };
layout(std430, set = 1, binding = 3) buffer RC_CellList   { uint  gRC_CellList[]; };

// ----------------------- push constants ---------------------------------------
layout(push_constant) uniform Push {
    uint MaxSteps;       // sphere-trace iteration cap
    float MinStep;       // floor on per-step march to avoid stalls
    float MaxDistance;   // ray budget in world units
    uint  _pad0;
} pc;

// ----------------------- helpers ---------------------------------------------

vec2 RC_Hammersley(uint i, uint N) {
    uint bits = i;
    bits = (bits << 16u) | (bits >> 16u);
    bits = ((bits & 0x55555555u) << 1u) | ((bits & 0xAAAAAAAAu) >> 1u);
    bits = ((bits & 0x33333333u) << 2u) | ((bits & 0xCCCCCCCCu) >> 2u);
    bits = ((bits & 0x0F0F0F0Fu) << 4u) | ((bits & 0xF0F0F0F0u) >> 4u);
    bits = ((bits & 0x00FF00FFu) << 8u) | ((bits & 0xFF00FF00u) >> 8u);
    return vec2(float(i) / float(N), float(bits) * 2.3283064365386963e-10);
}

vec3 RC_SphereDir(vec2 xi) {
    float phi   = 6.2831853 * xi.x;
    float cosT  = 1.0 - 2.0 * xi.y;
    float sinT  = sqrt(max(0.0, 1.0 - cosT * cosT));
    return vec3(cos(phi) * sinT, cosT, sin(phi) * sinT);
}

vec4 RC_FetchNextCascadeSh(vec3 worldPos, uint cascade) {
    int  cascadeCount = int(gRC_P.CascadeParams.y);
    uint nextC = min(cascade + 1u, uint(cascadeCount - 1));
    vec3 eye   = gRC_P.EyePosAndHashLog2.xyz;
    float s0   = gRC_P.CascadeParams.x;

    ivec3 cell = RC_WorldToCell(worldPos, eye, s0, nextC);
    uint  key  = RC_PackKey(cell, nextC);

    const uint N = gRC_Keys.length();
    const uint mask = N - 1u;
    uint slot = RC_HashWord(key) & mask;
    for (uint probe = 0u; probe < 8u; ++probe) {
        uint stored = gRC_Keys[slot];
        if (stored == 0u)  return vec4(0.0);
        if (stored == key) return gRC_Payload[slot];
        slot = (slot + 1u) & mask;
    }
    return vec4(0.0);
}

// ----------------------- main ------------------------------------------------

void main() {
    uint cellIdx = gl_GlobalInvocationID.x;
    uint count   = gRC_CellList[0];
    if (cellIdx >= count) return;

    uint key = gRC_CellList[cellIdx + 1u];
    if (key == 0u) return;

    const uint N = gRC_Keys.length();
    const uint mask = N - 1u;
    uint slot = RC_HashWord(key) & mask;
    for (uint probe = 0u; probe < 8u; ++probe) {
        if (gRC_Keys[slot] == key) break;
        if (gRC_Keys[slot] == 0u)  return;
        slot = (slot + 1u) & mask;
    }

    ivec3 cell; uint cascade;
    RC_UnpackKey(key, cell, cascade);

    vec3 eye   = gRC_P.EyePosAndHashLog2.xyz;
    float s0   = gRC_P.CascadeParams.x;
    vec3 probePos = RC_CellCenterWorld(cell, eye, s0, cascade);

    // World→mesh-local transform. The SDF AABB + brick grid are authored in
    // OBJ-local space (cm for ShaderBall); probePos is world-space metres. We
    // trace entirely in local space — mirrors lighting_sdfcone.comp's per-pixel
    // invModel mapping — then map hit/miss endpoints back to world for the SH.
    mat4 worldToLocal = mat4(gRC_P.WorldToLocal0,
                             gRC_P.WorldToLocal1,
                             gRC_P.WorldToLocal2,
                             gRC_P.WorldToLocal3);
    float scaleLocalPerWorld = max(gRC_P.SecondaryParams.w, 1e-6);
    float localPerWorldInv   = 1.0 / scaleLocalPerWorld;   // world metres / local unit
    vec3 probePosLocal = (worldToLocal * vec4(probePos, 1.0)).xyz;

    int rayCount = int(gRC_P.CascadeParams.z);
    rayCount = clamp(rayCount, 4, 64);

    float cellPitch = RC_CellPitch(s0, cascade);
    float maxDist   = max(pc.MaxDistance, cellPitch * 4.0);
    // Trace budgets are world-unit tunables; remap onto the local-space trace.
    float maxDistLocal = maxDist * scaleLocalPerWorld;

    uint jitter = uint(gRC_P.SecondaryParams.z) ^ key;
    float jitterX = float(RC_HashWord(jitter)) * 2.3283064365386963e-10;
    float jitterY = float(RC_HashWord(jitter ^ 0x9E3779B9u)) * 2.3283064365386963e-10;

    vec3  sunDir       = normalize(gRC_P.SunDirAndIntensity.xyz);
    float sunIntensity = gRC_P.SunDirAndIntensity.w;
    vec3  sunColor     = gRC_P.SunColor.rgb;
    float sunLuma      = dot(sunColor * sunIntensity, vec3(0.2126, 0.7152, 0.0722));
    float ambientLuma  = gRC_P.SunColor.w;

    float tMinWorld = max(cellPitch * 0.05, 0.005);
    float tMinLocal = tMinWorld * scaleLocalPerWorld;
    float minStepLocal = max(pc.MinStep * scaleLocalPerWorld, 1e-4);

    vec4 shAccum = vec4(0.0);
    float weightSum = 0.0;

    for (int i = 0; i < rayCount; ++i) {
        vec2 xi = RC_Hammersley(uint(i), uint(rayCount));
        xi.x = fract(xi.x + jitterX);
        xi.y = fract(xi.y + jitterY);
        vec3 dirWorld = RC_SphereDir(xi);

        // Rotate the ray into mesh-local space and renormalize. mat3(worldToLocal)
        // carries the inverse-model rotation+scale; we trace with a unit local
        // direction so the SDF's IQ distances stay in local units.
        vec3 dirLocal = normalize(mat3(worldToLocal) * dirWorld);

        // Sun direction toward light, in local space (for NdotL + cone shadow).
        vec3 sunDirLocal = normalize(mat3(worldToLocal) * sunDir);

        vec3 outPosLocal, outNormalLocal;
        float outDist;
        bool hit = SDF_TraceHitSparse(probePosLocal, dirLocal,
                                      tMinLocal, maxDistLocal,
                                      int(pc.MaxSteps), minStepLocal,
                                      uSparseP.P,
                                      outPosLocal, outNormalLocal, outDist);

        float radianceLuma = 0.0;
        if (hit) {
            // Normal from the SDF gradient is already in local space; for a
            // dot against the local sun dir that's consistent (rotation only
            // affects both equally). Soft shadow traces in local too.
            float NdotL = max(dot(outNormalLocal, sunDirLocal), 0.0);
            float vis = SDF_SoftShadowSparse(outPosLocal, sunDirLocal,
                                             maxDistLocal, 32.0,
                                             int(pc.MaxSteps), minStepLocal,
                                             uSparseP.P);
            radianceLuma = sunLuma * NdotL * vis + ambientLuma;
        } else {
            // Miss — endpoint is local; map back to world for the next-cascade
            // SH lookup, which is keyed in world-space cells (insert uses world).
            vec3 outPosWorld = probePos + dirWorld * (outDist * localPerWorldInv);
            vec4 nextSh = RC_FetchNextCascadeSh(outPosWorld, cascade);
            radianceLuma = max(nextSh.x * 3.14159265 * kSH_Y00, 0.0);
            radianceLuma += max(dirWorld.y, 0.0) * ambientLuma * 0.5;
        }

        shAccum += RC_ProjectShL1(dirWorld, radianceLuma);
        weightSum += 1.0;
    }

    if (weightSum > 0.0) {
        shAccum *= (4.0 * 3.14159265) / weightSum;
    }

    vec4 prev = gRC_Payload[slot];
    float alpha = 0.25;
    gRC_Payload[slot] = mix(prev, shAccum, alpha);
}
